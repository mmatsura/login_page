{
  "version": 2,
  "name": "login-page",
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}