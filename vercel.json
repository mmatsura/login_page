{
  "version": 2,
  "name": "login-page",
  "builds": [
    {
      "src": "index.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}